    {
      "parameters": {
        "content": "🟡 TRATAMENTO DA ENTRADA\n\n- Remove espaços\n- Converte para minúsculo\n- Remove acentos\n- Normaliza texto\n\nSalva na variável: queue"
      },
      "type": "n8n-nodes-base.stickyNote",
      "position": [
        208,
        -176
      ],
      "typeVersion": 1,
      "id": "d2bec6eb-1e11-444e-89a6-61b1fd586c47",
      "name": "TRATAMENTO"
    },
    {
      "parameters": {
        "content": "🔵 CONSULTA API OPENWEATHER\n\nEnvia:\n- q (cidade)\n- units=metric\n- lang=pt_br\n- appid\n\nRetorna dados de clima + código HTTP"
      },
      "type": "n8n-nodes-base.stickyNote",
