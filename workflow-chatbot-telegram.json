              "type": "string"
            },
            {
              "id": "f9904837-5123-46b4-8212-d8aa64d43d90",
              "name": "cidade",
              "value": "={{ $json[\"message\"][\"text\"]?.trim().normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\").split(\",\")[0].trim().toLowerCase().replace(/\\s+/g, \" \") }}",
              "type": "string"
            }
          ]
